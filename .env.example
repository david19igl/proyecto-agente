# =============================================================================
# .env.example — copia como .env y rellena los valores reales
# NUNCA subas el .env real a un repositorio git (.gitignore lo excluye)
# =============================================================================

# --- OMDb API ----------------------------------------------------------------
# Registro gratuito en https://www.omdbapi.com/apikey.aspx (1000 req/día)
OMDB_API_KEY=tu_api_key_aqui

# --- Telegram ----------------------------------------------------------------
# Crear bot con @BotFather → copiar el token
# Obtener tu chat_id con @userinfobot
TELEGRAM_TOKEN=123456789:ABCdef_tu_token_aqui
TELEGRAM_CHAT_ID=123456789

# --- Email (opcional, alternativa a Telegram) --------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password_de_google
NOTIFY_EMAIL=destinatario@ejemplo.com

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379
CACHE_TTL=86400

# --- Cron (lunes a las 09:00) ------------------------------------------------
CRON_SCHEDULE=0 9 * * 1 python /app/scraper/weekly_report.py >> /app/logs/cron.log 2>&1

# --- Web ---------------------------------------------------------------------
FLASK_ENV=development
SECRET_KEY=cambia_esto_en_produccion

# --- Logs --------------------------------------------------------------------
LOG_LEVEL=INFO
